# Copy to .env and adjust as needed. All values have sensible defaults.

# Database (SQLite by default; use postgresql+psycopg://user:pass@host/db for Postgres)
ISO13485_DATABASE_URL=sqlite:///./audit.db

# NLP backend: "tfidf" (default, offline) or "transformer" (requires the [nlp] extra)
ISO13485_NLP_BACKEND=tfidf
ISO13485_NLP_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Gap-detection thresholds (cosine similarity, 0..1)
ISO13485_GAP_SIMILARITY_THRESHOLD=0.12
ISO13485_GAP_HIGH_CONFIDENCE_THRESHOLD=0.30

# File system locations
ISO13485_UPLOAD_DIR=./uploads
ISO13485_REPORT_OUTPUT_DIR=./reports_output

# API
ISO13485_API_PREFIX=/api/v1
ISO13485_LOG_LEVEL=INFO
